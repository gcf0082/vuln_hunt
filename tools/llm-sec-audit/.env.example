baseURL=https://your-api-endpoint/v1
apiKey=your-api-key
model=glm-4.7

# Optional sampling/length parameters. Leave commented to use provider defaults
# (except maxTokens which defaults to 8192 since some providers default to a
# value too small for reasoning models).
#maxTokens=8192
#temperature=0.7
#topP=0.95
#presencePenalty=0.0
#frequencyPenalty=0.0

# Request timeout in seconds (0 or unset = no timeout)
#timeout=120

# Set to true to stream the model's thinking/reasoning to stderr wrapped
# in <think>...</think>. Default is hidden.
#showThinking=false

# Verify TLS certificates of the API endpoint. Defaults to false (skip
# verification) so self-signed proxies / corporate gateways work out of
# the box. Set to true in production with a trusted certificate chain.
#verifyTLS=false

# Optional extra HTTP headers, comma-separated key=value pairs
#headers=X-Custom-Header=value,X-Another-Header=another-value
